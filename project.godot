[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="player"
3d_physics/layer_3="enemy"
3d_physics/layer_4="player_hitbox"
3d_physics/layer_5="enemy_hitbox"
3d_physics/layer_6="player_hurtbox"
3d_physics/layer_7="enemy_hurtbox"

[physics]

; Deterministic combat: fixed 60 Hz tick, smoothed by physics interpolation,
; with capped catch-up steps to avoid a spiral of death (ARCHITECTURE.md §3).
common/physics_ticks_per_second=60
common/max_physics_steps_per_frame=8
common/physics_interpolation=true
3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
